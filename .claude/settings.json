{
  "permissions": {
    "allow": [
      "Bash(cargo doc*)",
      "Bash(cargo bench*)",
      "Bash(cargo test*)",
      "Bash(cargo check*)",
      "Bash(cargo build*)",
      "Bash(just *)",
      "Bash(git *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(sed *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(diff *)",
        "mcp__cclsp__find_workspace_symbols",
        "mcp__cclsp__get_hover",
        "mcp__cclsp__find_implementation",
        "mcp__cclsp__find_definition",
        "mcp__cclsp__find_references",
        "mcp__cclsp__get_diagnostics",
        "mcp__cclsp__prepare_call_hierarchy",
        "mcp__cclsp__get_incoming_calls",
        "mcp__cclsp__get_outgoing_calls",
        "mcp__cclsp__rename_symbol",
        "mcp__cclsp__rename_symbol_strict"

    ]
  },
  "ignorePatterns": [
    "docs/compiler",
    "target",
    "tasks/benchmark/benches/compiler/*",
    "tasks/compiler_tests/cases2/*/case-svelte.js",
    "tasks/compiler_tests/cases2/*/case-rust.js",
    "REVIEW.md"
  ],
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  }
}
